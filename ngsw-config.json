{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css"
        ]
      }
    },
    {
      "name": "app-js",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/icons/*",
          "/images/*",
          "/**/*.+(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-articles",
      "urls": [
        "/api/v1/articles",
        "/api/v1/articles/*"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "10m",
        "timeout": "5s"
      }
    },
    {
      "name": "api-tags",
      "urls": [
        "/api/v1/tags"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "10m",
        "timeout": "5s"
      }
    },
    {
      "name": "api-profile",
      "urls": [
        "/api/v1/profile"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 5,
        "maxAge": "10m",
        "timeout": "5s"
      }
    },
    {
      "name": "google-fonts",
      "urls": [
        "https://fonts.googleapis.com/**",
        "https://fonts.gstatic.com/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "365d"
      }
    },
    {
      "name": "admin-network-only",
      "urls": [
        "/api/v1/admin/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 0,
        "maxAge": "0u",
        "timeout": "0u"
      }
    },
    {
      "name": "auth-network-only",
      "urls": [
        "/api/v1/admin/auth/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 0,
        "maxAge": "0u",
        "timeout": "0u"
      }
    },
    {
      "name": "mutations-network-only",
      "urls": [
        "/api/v1/articles/*/like",
        "/api/v1/articles/*/comments",
        "/api/v1/contact",
        "/api/v1/newsletter/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 0,
        "maxAge": "0u",
        "timeout": "0u"
      }
    }
  ]
}
